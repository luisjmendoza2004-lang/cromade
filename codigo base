<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CROMADE — Más allá del último día</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="landing.css">
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
</head>
<body>
    <!-- NAVIGATION -->
    <nav class="nav-landing" id="navbar">
        <div class="nav-container">
            <a href="#" class="nav-logo">
                <span class="nav-logo-icon">◉</span>
                <span class="nav-logo-text">CROMADE</span>
            </a>
            <div class="nav-links">
                <a href="#experiencia" class="nav-link">Experiencia</a>
                <a href="#capitulos" class="nav-link">Capítulos</a>
                <a href="#testimonios" class="nav-link">Testimonios</a>
                <a href="#precios" class="nav-link">Precios</a>
                <a href="#faq" class="nav-link">FAQ</a>
            </div>
            <div class="nav-actions">
                <button class="btn-nav-login" onclick="landingApp.showLoginModal()">Iniciar Sesión</button>
                <button class="btn-nav-cta" onclick="landingApp.scrollToApp()">Comenzar Viaje</button>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero-landing">
        <div class="hero-bg">
            <div class="hero-bg-overlay"></div>
        </div>
        <div class="hero-content">
            <div class="hero-badge-container">
                <span class="hero-badge">🎬 Experiencia Inmersiva Interactiva</span>
                <span class="hero-badge-secondary">Novedad 2026</span>
            </div>
            <h1 class="hero-title">
                <span class="hero-title-line">Más allá</span>
                <span class="hero-title-line gradient-text">del último día</span>
            </h1>
            <p class="hero-subtitle">
                Una novela de ciencia ficción filosófica que no solo se lee.<br>
                Se <strong>vive</strong>. Se <strong>escucha</strong>. Se <strong>juega</strong>. Se <strong>transforma</strong>.
            </p>
            <div class="hero-stats-row">
                <div class="hero-stat-item"><span class="hero-stat-num">12</span><span class="hero-stat-label">Capítulos</span></div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat-item"><span class="hero-stat-num">3</span><span class="hero-stat-label">Modos</span></div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat-item"><span class="hero-stat-num">60+</span><span class="hero-stat-label">Quizzes</span></div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat-item"><span class="hero-stat-num">4</span><span class="hero-stat-label">Visuales</span></div>
            </div>
            <div class="hero-cta-group">
                <button class="btn-hero-primary" onclick="landingApp.openTrailerModal()">
                    <span class="btn-icon">▶</span><span>Ver Trailer</span><small>Gratis · 90 segundos</small>
                </button>
                <button class="btn-hero-secondary" onclick="landingApp.goToFreeChapter()">
                    <span>📖 Leer Capítulo 1</span><small>Gratis · Sin registro</small>
                </button>
            </div>
        </div>
    </section>

    <!-- SINOPSIS -->
    <section class="section-landing" id="sinopsis">
        <div class="section-container-landing">
            <div class="sinopsis-layout">
                <div class="sinopsis-content-landing">
                    <span class="section-tag-landing">La Historia</span>
                    <h2 class="section-title-landing">El silencio deja de ser opción</h2>
                    <div class="sinopsis-body">
                        <p class="sinopsis-lead">
                            En un mundo donde la Humanidad alcanzó la singularidad solo para descubrir que la verdadera evolución comienza cuando el silencio cesa de ser una opción, <strong>Juliana Voss</strong> se quita su máscara de iris y escucha algo que no proviene de ningún dispositivo: el <strong>Vínculo Primordial</strong>.
                        </p>
                        <blockquote class="sinopsis-quote">
                            <span class="quote-mark">"</span>
                            No nos controlan con miedo, nos controlan con comodidad. La jaula más perfecta es aquella que el prisionero confunde con su hogar.
                            <cite>— Dr. Elias Varela</cite>
                        </blockquote>
                    </div>
                    <div class="sinopsis-meta-landing">
                        <span class="meta-tag-landing">Ciencia Ficción</span>
                        <span class="meta-tag-landing">Filosofía</span>
                        <span class="meta-tag-landing">Distopía</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- EXPERIENCIA -->
    <section class="section-landing section-dark" id="experiencia">
        <div class="section-container-landing">
            <div class="section-header-landing">
                <span class="section-tag-landing center">¿Cómo funciona?</span>
                <h2 class="section-title-landing center">No es un libro. Es un <span class="gradient-text">universo</span>.</h2>
            </div>
            <div class="features-layout">
                <div class="feature-card-large">
                    <div class="feature-content">
                        <div class="feature-icon-large">📖</div>
                        <h3>Modo Lectura Inmersiva</h3>
                        <p>Tipografía editorial diseñada para lectura profunda. Capítulos 1-2 completamente gratis.</p>
                        <ul class="feature-list">
                            <li>✓ 12 capítulos de prosa filosófica</li>
                            <li>✓ Progreso de lectura guardado</li>
                            <li>✓ Tamaño de fuente ajustable</li>
                        </ul>
                    </div>
                </div>
                <div class="feature-card-large">
                    <div class="feature-content">
                        <div class="feature-icon-large">🔊</div>
                        <h3>Audiolibro TTS Inteligente</h3>
                        <p>Voz sintética de alta calidad con velocidad ajustable. PREMIUM.</p>
                        <ul class="feature-list">
                            <li>✓ Velocidad 1x, 1.5x, 2x</li>
                            <li>✓ Visualizador de ondas animado</li>
                            <li>✓ Funciona offline</li>
                        </ul>
                    </div>
                </div>
                <div class="feature-card-large">
                    <div class="feature-content">
                        <div class="feature-icon-large">🎬</div>
                        <h3>Capítulos Visuales</h3>
                        <p>Storyboard interactivo tipo serie. 4 capítulos transformados en experiencia audiovisual. PREMIUM.</p>
                        <ul class="feature-list">
                            <li>✓ 4 capítulos con escenas visuales</li>
                            <li>✓ Diálogos interactivos</li>
                            <li>✓ Transiciones cinematográficas</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CAPITULOS -->
    <section class="section-landing" id="capitulos">
        <div class="section-container-landing">
            <div class="section-header-landing">
                <span class="section-tag-landing center">Estructura</span>
                <h2 class="section-title-landing center">12 Capítulos · 3 Actos · 1 <span class="gradient-text">Destino</span></h2>
                <p class="section-subtitle-landing">Capítulo 1 gratis. Capítulo 2 gratis tras registro. El resto, desbloquea tu viaje.</p>
            </div>
            <div class="chapters-timeline-landing">
                <div class="timeline-act-landing">
                    <div class="act-badge">ACTO I</div>
                    <h3 class="act-title-landing">El Despertar</h3>
                    <p class="act-desc-landing">Caps 1-2 · Gratis</p>
                </div>
                <div class="timeline-chapters-landing">
                    <div class="timeline-chapter-landing chapter-free" onclick="landingApp.goToChapter(1)">
                        <div class="tc-content">
                            <span class="tc-num">I</span>
                            <h4 class="tc-title">El Despertar del Vínculo</h4>
                            <p class="tc-desc">Juliana se quita la máscara. El silencio habla.</p>
                            <div class="tc-badges"><span class="tc-badge-free">GRATIS</span><span class="tc-badge-time">25 min</span></div>
                        </div>
                    </div>
                    <div class="timeline-chapter-landing chapter-free-reg" onclick="landingApp.goToChapter(2)">
                        <div class="tc-content">
                            <span class="tc-num">II</span>
                            <h4 class="tc-title">Los Arquitectos del Silencio</h4>
                            <p class="tc-desc">La verdad detrás del control. La biblioteca resiste.</p>
                            <div class="tc-badges"><span class="tc-badge-free-reg">GRATIS tras registro</span><span class="tc-badge-time">30 min</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="chapters-cta-landing">
                <button class="btn-chapters-cta" onclick="landingApp.goToFreeChapter()">
                    <span>🚀 Comenzar con el Capítulo 1 Gratis</span>
                </button>
            </div>
        </div>
    </section>

    <!-- PRECIOS -->
    <section class="section-landing" id="precios">
        <div class="section-container-landing">
            <div class="section-header-landing">
                <span class="section-tag-landing center">Acceso</span>
                <h2 class="section-title-landing center">Elige tu <span class="gradient-text">camino</span></h2>
            </div>
            <div class="pricing-grid-landing">
                <div class="pricing-card-landing">
                    <div class="pricing-header">
                        <div class="pricing-badge-landing">Gratis</div>
                        <h3 class="pricing-name">Explorador</h3>
                        <div class="pricing-price-landing"><span class="price-currency">$</span><span class="price-num">0</span><span class="price-period">/mes</span></div>
                    </div>
                    <ul class="pricing-features-landing">
                        <li class="feature-included"><span class="feature-check">✓</span> Capítulo 1 completo</li>
                        <li class="feature-included"><span class="feature-check">✓</span> Modo lectura</li>
                        <li class="feature-excluded"><span class="feature-x">✗</span> Capítulo 2+</li>
                        <li class="feature-excluded"><span class="feature-x">✗</span> Audiolibro</li>
                    </ul>
                    <button class="btn-pricing" onclick="landingApp.goToFreeChapter()">Probar Gratis</button>
                </div>
                <div class="pricing-card-landing featured">
                    <div class="pricing-header">
                        <div class="pricing-badge-landing pricing-badge-popular">Popular</div>
                        <h3 class="pricing-name">Viajero</h3>
                        <div class="pricing-price-landing"><span class="price-currency">$</span><span class="price-num">4.99</span><span class="price-period">/mes</span></div>
                    </div>
                    <ul class="pricing-features-landing">
                        <li class="feature-included"><span class="feature-check">✓</span> Todos los capítulos</li>
                        <li class="feature-included"><span class="feature-check">✓</span> Modo lectura + audio</li>
                        <li class="feature-included"><span class="feature-check">✓</span> Todos los quizzes</li>
                        <li class="feature-included"><span class="feature-check">✓</span> 4 Capítulos visuales</li>
                    </ul>
                    <button class="btn-pricing btn-pricing-primary" onclick="landingApp.startSubscription('monthly')">Suscribirse Mensual</button>
                </div>
                <div class="pricing-card-landing">
                    <div class="pricing-header">
                        <div class="pricing-badge-landing">Apoyo</div>
                        <h3 class="pricing-name">Mecenas</h3>
                        <div class="pricing-price-landing"><span class="price-currency">$</span><span class="price-num">?</span><span class="price-period">tu eliges</span></div>
                    </div>
                    <ul class="pricing-features-landing">
                        <li class="feature-included"><span class="feature-check">✓</span> Todo lo de Arquitecto</li>
                        <li class="feature-included"><span class="feature-check">✓</span> Acceso anticipado</li>
                    </ul>
                    <div class="donation-buttons-landing">
                        <button class="btn-donation" onclick="landingApp.donate(5)">$5</button>
                        <button class="btn-donation" onclick="landingApp.donate(10)">$10</button>
                        <button class="btn-donation" onclick="landingApp.donate(20)">$20</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-landing section-dark" id="faq">
        <div class="section-container-landing">
            <div class="section-header-landing">
                <span class="section-tag-landing center">Preguntas</span>
                <h2 class="section-title-landing center">Todo lo que necesitas <span class="gradient-text">saber</span></h2>
            </div>
            <div class="faq-grid">
                <div class="faq-item">
                    <button class="faq-question" onclick="landingApp.toggleFaq(this)">
                        <span>¿Realmente es gratis el Capítulo 1?</span><span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer"><p>Sí, completamente. Sin registro, sin tarjeta, sin compromiso.</p></div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" onclick="landingApp.toggleFaq(this)">
                        <span>¿Qué necesito para el Capítulo 2?</span><span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer"><p>Solo un registro con email. No pedimos tarjeta ni pago.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="section-cta-final">
        <div class="cta-final-content">
            <h2>El silencio está <span class="gradient-text">esperando</span></h2>
            <p>¿Serás tú el siguiente?</p>
            <div class="cta-final-buttons">
                <button class="btn-cta-final-primary" onclick="landingApp.goToFreeChapter()">
                    <span>📖 Leer Capítulo 1 Gratis</span><small>Sin registro · Sin tarjeta</small>
                </button>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer-landing">
        <div class="footer-container">
            <div class="footer-brand">
                <div class="footer-logo"><span class="footer-logo-icon">◉</span><span class="footer-logo-text">CROMADE</span></div>
                <p class="footer-tagline">Más allá del último día</p>
            </div>
            <div class="footer-links-group">
                <div class="footer-links-col">
                    <h4>Experiencia</h4>
                    <a href="#experiencia">Modos de lectura</a>
                    <a href="#capitulos">Capítulos</a>
                    <a href="#precios">Precios</a>
                </div>
                <div class="footer-links-col">
                    <h4>Legal</h4>
                    <a href="#" onclick="landingApp.showTerms()">Términos</a>
                    <a href="#" onclick="landingApp.showPrivacy()">Privacidad</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2026 CROMADE. Todos los derechos reservados.</p>
        </div>
    </footer>

    <!-- LOGIN MODAL -->
    <div class="modal-overlay" id="loginModal">
        <div class="modal-auth-landing">
            <button class="modal-close-btn" onclick="landingApp.closeLoginModal()">×</button>
            <div class="auth-tabs-landing">
                <button class="auth-tab-landing active" onclick="landingApp.switchAuthTab('login')">Iniciar Sesión</button>
                <button class="auth-tab-landing" onclick="landingApp.switchAuthTab('register')">Crear Cuenta</button>
            </div>
            <div class="auth-panel-landing active" id="loginPanel">
                <h3>Bienvenido de vuelta</h3>
                <form onsubmit="landingApp.handleLogin(event)">
                    <div class="form-group-landing"><label>Email</label><input type="email" id="loginEmail" placeholder="tu@email.com" required></div>
                    <div class="form-group-landing"><label>Contraseña</label><input type="password" id="loginPassword" placeholder="Tu contraseña" required></div>
                    <button type="submit" class="btn-auth-submit-landing">Iniciar Sesión</button>
                </form>
            </div>
            <div class="auth-panel-landing" id="registerPanel">
                <h3>Unite a los Arquitectos</h3>
                <form onsubmit="landingApp.handleRegister(event)">
                    <div class="form-group-landing"><label>Nombre</label><input type="text" id="regName" placeholder="Tu nombre" required></div>
                    <div class="form-group-landing"><label>Email</label><input type="email" id="regEmail" placeholder="tu@email.com" required></div>
                    <div class="form-group-landing"><label>Contraseña</label><input type="password" id="regPassword" placeholder="Mínimo 8 caracteres" required minlength="8"></div>
                    <button type="submit" class="btn-auth-submit-landing">Crear Cuenta Gratis</button>
                </form>
            </div>
        </div>
    </div>

    <!-- PAYMENT MODAL -->
    <div class="modal-overlay" id="paymentModal">
        <div class="modal-payment">
            <button class="modal-close-btn" onclick="landingApp.closePaymentModal()">×</button>
            <h3 id="paymentTitle">Suscribirse</h3>
            <div class="payment-methods-landing">
                <div class="payment-method-landing" onclick="landingApp.selectPayment('mercadopago')">
                    <div class="payment-method-icon">💳</div>
                    <div class="payment-method-info"><span class="payment-method-name">MercadoPago</span></div>
                </div>
            </div>
            <div id="paymentDetails"></div>
        </div>
    </div>

    <div class="toast-container-landing" id="toastContainer"></div>
    <script src="landing.js"></script>
</body>
</html>
